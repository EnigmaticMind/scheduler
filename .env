# Loaded by `make` targets and by `docker compose` for variable substitution.
# Override any value locally; do not commit secrets in shared repos.

# HTTP server (empty uses default :8080 in the app)
PORT=8080

# Postgres role and database (used by the db service and to build DATABASE_URLs)
POSTGRES_USER=scheduler
POSTGRES_PASSWORD=scheduler
POSTGRES_DB=scheduler

# Host port mapped to Postgres (change DATABASE_URL below if you change this)
POSTGRES_PORT=5432

# Connection URL when running the app on your machine (`make run`) against Docker Postgres on localhost.
# Keep credentials in sync with POSTGRES_* above.
DATABASE_URL=postgres://scheduler:scheduler@localhost:5432/scheduler?sslmode=disable
