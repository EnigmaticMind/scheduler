{
  "info": {
    "_postman_id": "c55d71ff-22eb-4d97-aa82-febf7329f23f",
    "name": "Scheduler API",
    "description": "Local Scheduler API. Successful list/create responses use `{ \"data\": [ ... ] }` with objects containing `id`, `user_id`, `trainer_id`, `started_at`, `ended_at` (RFC3339). Errors use `{ \"error\": \"message\" }`. Query and body times must be RFC3339.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    },
    {
      "key": "trainerId",
      "value": "1"
    },
    {
      "key": "userId",
      "value": "123"
    },
    {
      "key": "startsAt",
      "value": "2026-04-15T16:00:00Z"
    },
    {
      "key": "endsAt",
      "value": "2026-04-15T17:00:00Z"
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "description": "Returns plain text `ok` with HTTP 200.",
        "url": {
          "raw": "{{baseUrl}}/health",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["health"]
        }
      }
    },
    {
      "name": "List available appointments",
      "request": {
        "method": "GET",
        "header": [],
        "description": "Returns unbooked 30-minute slots for the trainer within `[starts_at, ends_at)` (weekdays, Pacific business hours). Requires `trainer_id`, `starts_at`, and `ends_at` query parameters.",
        "url": {
          "raw": "{{baseUrl}}/appointments?trainer_id={{trainerId}}&starts_at={{startsAt}}&ends_at={{endsAt}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["appointments"],
          "query": [
            {
              "key": "trainer_id",
              "value": "{{trainerId}}"
            },
            {
              "key": "starts_at",
              "value": "{{startsAt}}"
            },
            {
              "key": "ends_at",
              "value": "{{endsAt}}"
            }
          ]
        }
      }
    },
    {
      "name": "Create appointment",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "description": "Books a slot: `starts_at` must fall on a weekday in Pacific time on a :00 or :30 boundary within business hours; appointments are 30 minutes.",
        "body": {
          "mode": "raw",
          "raw": "{\n  \"trainer_id\": {{trainerId}},\n  \"user_id\": {{userId}},\n  \"starts_at\": \"{{startsAt}}\",\n  \"ends_at\": \"{{endsAt}}\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/appointments",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["appointments"]
        }
      }
    },
    {
      "name": "List scheduled appointments",
      "request": {
        "method": "GET",
        "header": [],
        "description": "Returns existing appointments for the trainer from the database.",
        "url": {
          "raw": "{{baseUrl}}/appointments/schedules?trainer_id={{trainerId}}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["appointments", "schedules"],
          "query": [
            {
              "key": "trainer_id",
              "value": "{{trainerId}}"
            }
          ]
        }
      }
    }
  ]
}
